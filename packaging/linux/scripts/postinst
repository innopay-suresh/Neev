#!/bin/bash
set -euo pipefail

case "${1:-configure}" in
  configure)
    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl enable remote-agent.service >/dev/null 2>&1 || true
    systemctl restart remote-agent.service >/dev/null 2>&1 || systemctl start remote-agent.service >/dev/null 2>&1 || true
    ;;
esac

exit 0
